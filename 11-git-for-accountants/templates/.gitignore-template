# ===========================
*.env
.env.*
credentials.*
secrets.*
*.pem
*.key
*.pfx

# ===========================
# FINANCIAL DATA
# ===========================
data/raw/*.xlsx
data/raw/*.xls
*.db
*.sqlite
*.sqlite3
*.bak

